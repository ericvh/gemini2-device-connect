# Copy to gemini2.config.yaml and adjust, or set these in .env

# Connection mode: auto | portal | d2d
# DEVICE_CONNECT_MODE=portal

# Portal credentials (downloaded from https://portal.deviceconnect.dev)
# NATS_CREDENTIALS_FILE=~/your-device.creds.json
# NATS_URL=nats://portal.deviceconnect.dev:4222
# MESSAGING_BACKEND=nats

# Device identity (optional — inferred from credentials file)
# DEVICE_ID=your-tenant-orbbec-001

# Local D2D development fallback
# DEVICE_CONNECT_ALLOW_INSECURE=true

# Orbbec SDK / runtime
# ORBBEC_SDK_DIR=vendor/orbbec/OrbbecSDK_v2.8.6_202604271452_6399409_linux_arm64
# GEMINI2_VENV=.venv
# GEMINI2_EMIT_INTERVAL=1.0
# GEMINI2_CONFIG=gemini2.config.yaml
